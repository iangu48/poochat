{
  "expo": {
    "name": "poochat",
    "slug": "poochat",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.anonymous.poochat",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Poochat uses your location to place logs on your map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Poochat uses your location to place logs on your map."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-location"
    ]
  }
}
